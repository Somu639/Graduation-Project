# ---------------------------------------------------------------------------
# Spotify Discovery Analyzer - environment configuration
# Copy this file to `.env` and fill in your own values.
# ---------------------------------------------------------------------------

# --- LLM provider selection: "openai" or "anthropic" ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# --- Embeddings: "openai", "voyage", or "huggingface" (local) ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
# VOYAGE_API_KEY=your-voyage-key   # only when EMBEDDING_PROVIDER=voyage

# --- Vector store: "chroma" (local/server) or "pinecone" (cloud) ---
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./.chroma
# When using the chromadb service (docker-compose), set these instead:
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

# --- Pinecone (only needed when VECTOR_STORE=pinecone) ---
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=spotify-discovery
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=1536

# --- Reddit API (PRAW) ---
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=spotify-discovery-analyzer/1.0

# --- Twitter / X API v2 ---
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# --- Datastore / relational DB (optional; for job metadata, future use) ---
DATABASE_URL=postgresql://user:password@localhost:5432/spotify_discovery

# --- Caching (Redis). If unset, an in-memory cache is used. ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# --- API rate limiting for LLM-heavy endpoints ---
LLM_RATE_LIMIT=20
LLM_RATE_PERIOD=60

# --- Frontend ---
API_BASE_URL=http://localhost:8000/api/v1

# --- n8n workflow automation ---
SDA_API_BASE=http://localhost:8000/api/v1
N8N_USER=admin
N8N_PASSWORD=changeme
